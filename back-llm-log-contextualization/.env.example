GRID_APP_ENVIRONMENT=development
GRID_APP_CORS_ALLOW_ORIGINS=["http://localhost:3000"]
GRID_APP_DATABASE_URL=postgresql+psycopg://grid_user:grid_password@localhost:5432/grid_logs
GRID_APP_STORAGE_DIR=./storage
GRID_APP_RAG_SEED_DIR=../context_file/logs_document

GRID_APP_MAX_UPLOAD_SIZE_BYTES=26214400
GRID_APP_ALLOWED_UPLOAD_EXTENSIONS=[".pdf"]

GRID_APP_API_KEY=
GRID_APP_RATE_LIMIT_ENABLED=true
GRID_APP_RATE_LIMIT_REQUESTS_PER_MINUTE=60

GRID_APP_JOB_TIMEOUT_SECONDS=120
GRID_APP_JOB_MAX_RETRIES=2
GRID_APP_MAX_CONCURRENT_JOBS=2

GRID_APP_LLM_PROVIDER=auto
GRID_APP_HF_TOKEN=
GRID_APP_HF_MODEL=katanemo/Arch-Router-1.5B:hf-inference
GRID_APP_OLLAMA_BASE_URL=http://localhost:11434
GRID_APP_OLLAMA_MODEL=llama3.2:1b
GRID_APP_LLM_TIMEOUT_SECONDS=20

# Optional Docker Compose overrides (kept separate to avoid clashing with local Python runs)
GRID_APP_DATABASE_URL_DOCKER=postgresql+psycopg://grid_user:grid_password@db:5432/grid_logs
GRID_APP_OLLAMA_BASE_URL_DOCKER=http://ollama:11434
